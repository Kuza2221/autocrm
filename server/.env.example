# Copy this to .env and fill in your values

# JWT Secret — generate a random 64-char string
JWT_SECRET=change-me-to-a-random-64-char-secret-string

# App port
PORT=3001

# Production URL (your Railway domain, e.g. https://autocrm.up.railway.app)
APP_URL=http://localhost:3001

# Google Calendar OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI API key (for AI Assistant, optional)
OPENAI_API_KEY=
